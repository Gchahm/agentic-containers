# Copy this file to infra/.env and fill in values.
# infra/*.sh scripts auto-source infra/.env when present.
# infra/.env is gitignored; only infra/.env.example is committed.
#
# Values here override any matching shell variables when the script runs.
# Anything left empty/commented falls back to the script's built-in defaults.

# ---------- AWS ----------
# Used by create-rds.sh. AWS credentials themselves come from ~/.aws/
# (via AWS_PROFILE) or AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars.
AWS_REGION=sa-east-1
# AWS_PROFILE=default

# ---------- RDS admin connection ----------
# Used by create-db.sh to connect to the existing RDS instance as the master
# (admin) user. Defaults assume the cloudflared tunnel is forwarding
# localhost:5432 to RDS — start the tunnel before running create-db.sh.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGSSLMODE=verify-ca
