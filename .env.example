export GIT_NAME=""
export GIT_EMAIL=""

# GitHub auth (used by gh CLI and git credential helper)
export GH_TOKEN=""
export GITHUB_USERNAME=""

# Claude Code auth (optional if using 'ac sync-auth'):
# export CLAUDE_CODE_OAUTH_TOKEN=""
# export ANTHROPIC_AUTH_TOKEN=""
# export ANTHROPIC_BASE_URL=""

# Cloudflare Tunnel (optional, for `ac tunnel` to expose containers publicly)
# Token needs: Account > Cloudflare Tunnel: Edit, Zone > DNS: Edit
# export CLOUDFLARE_API_TOKEN=""
# export CLOUDFLARE_ACCOUNT_ID=""
# export CLOUDFLARE_ZONE_ID=""
# export CLOUDFLARE_BASE_DOMAIN=""   # e.g. dev.example.com → tunnels at <name>.dev.example.com


# Cloudflare Access tunnel to shared RDS (optional).
# When all three are set, the container starts `cloudflared access tcp` on
# localhost:5432 and skips the local PostgreSQL. Apps connect to localhost:5432
# as usual and traffic is routed through the tunnel to RDS.
# See docs/cloudflare-tunnel-rds.md for the Cloudflare-side setup.
# export DB_TUNNEL_HOSTNAME=""       # e.g. db-dev.example.com
# export CF_ACCESS_CLIENT_ID=""      # Cloudflare Access service token ID
# export CF_ACCESS_CLIENT_SECRET=""  # Cloudflare Access service token secret
 
# Real AWS RDS endpoint — when set, `ac create` maps this to 127.0.0.1 inside
# the container so apps can connect via the cloudflared tunnel using the RDS
# hostname (and pass sslmode=verify-full). Pair with DB_TUNNEL_HOSTNAME above.
# export DB_RDS_HOSTNAME=""        # e.g. mydb.xxxxx.region.rds.amazonaws.com

